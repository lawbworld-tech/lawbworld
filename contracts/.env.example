# Deployer private key (0x-prefixed, 64 hex chars). NEVER commit the real one.
PRIVATE_KEY=

# RPC endpoints (override defaults if you have a paid provider)
BASE_RPC_URL=https://base.publicnode.com
BASE_SEPOLIA_RPC=https://base-sepolia.publicnode.com

# Etherscan v2 unified key — works for all chains including Base + Base Sepolia.
# Get one (free) at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Deploy params (deployer is used as fallback for any unset address)
ROYALTY_RECEIVER=
ROYALTY_BPS=500
MINT_SIGNER=
