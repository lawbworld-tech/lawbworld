# Lawbworld server config
PORT=3001
HOST=0.0.0.0

# Upstream gitlawb node — repo index is fetched from /node/repos on this base.
GITLAWB_BASE=https://gitlawb.com

# How often to re-fetch the repo index (minutes).
REPO_REFRESH_MIN=10
REPO_FETCH_TIMEOUT_MS=20000

# Environment mode (production disables /api/dev/* endpoints)
NODE_ENV=development

# ---- AI (OpenRouter) ----
# Sign up at https://openrouter.ai/keys — leave blank to disable /api/ai/*.
OPENROUTER_API_KEY=
# Cheap working option ($0.0000003 per image generated):
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_SITE_URL=https://lawbworld.local
OPENROUTER_APP_NAME=Lawbworld

# ---- On-chain wiring ----
# Network: 84532 = base-sepolia, 8453 = base mainnet
CHAIN_ID=84532
CHAIN_RPC=https://base-sepolia.publicnode.com
# UUPS proxy address from contracts/scripts/deploy.js output
LAWB_BUILDING_PROXY=
# Block to start indexing Minted/LevelUp events from (0 = from genesis)
INDEXER_FROM_BLOCK=0
INDEXER_POLL_MS=30000
# Private key of the address registered as `mintSigner` on the contract.
# For testnet this can be the deployer key. Rotate before mainnet via
# building.setMintSigner(<server-key-addr>) and put the matching key here.
MINT_SIGNER_KEY=
# Default mint signature deadline (seconds from now)
MINT_SIG_TTL_SEC=600
